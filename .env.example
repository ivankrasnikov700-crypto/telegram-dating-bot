# Miss Moldova Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Telegram bot token from @BotFather
BOT_TOKEN=

# PostgreSQL connection string (Railway provides this)
DATABASE_URL=

# Comma-separated list of Telegram user IDs with admin access
# Example: 123456789,987654321
ADMIN_IDS=

# Litecoin wallet address for receiving fan payments
LTC_ADDRESS=

# USDT wallet address (optional)
USDT_ADDRESS=

# Telegram channel/group IDs (set to 0 to disable)
MEDIA_CHANNEL_ID=0
ADMIN_CHANNEL_ID=0
VIP_CHANNEL_ID=0
CONTACT_MANAGER_ID=0

# Mini App public URL (set after Railway deployment)
# Example: https://miss-moldova.railway.app
MINI_APP_URL=

# LOCAL DEVELOPMENT ONLY — skips Telegram initData auth validation
# NEVER set to 1 in production!
MINI_APP_DEV=0
